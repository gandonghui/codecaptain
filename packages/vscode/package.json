{
  "name": "codecaptain",
  "displayName": "CodeCaptain",
  "description": "%extension.description%",
  "version": "1.13.3",
  "publisher": "fedaykindev",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/btriapitsyn/codecaptain.git"
  },
  "qna": "https://discord.gg/ZYRSdnwwKA",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "gpt",
    "agent",
    "coding",
    "chatgpt",
    "groq",
    "assistant",
    "opencode",
    "codecaptain"
  ],
  "icon": "assets/app-icon.png",
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onCommand:codecaptain.openSidebar",
    "onCommand:codecaptain.attachExplorerToChat",
    "onView:codecaptain.chatView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codecaptain",
          "title": "CodeCaptain",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "codecaptain": [
        {
          "type": "webview",
          "id": "codecaptain.chatView",
          "name": "%views.chat.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "codecaptain.openSidebar",
        "category": "CodeCaptain",
        "title": "%command.openSidebar.title%",
        "icon": {
          "light": "assets/icon.svg",
          "dark": "assets/icon-titlebar.svg"
        }
      },
      {
        "command": "codecaptain.focusChat",
        "category": "CodeCaptain",
        "title": "%command.focusChat.title%"
      },
      {
        "command": "codecaptain.restartApi",
        "category": "CodeCaptain",
        "title": "%command.restartApi.title%"
      },
      {
        "command": "codecaptain.showOpenCodeStatus",
        "category": "CodeCaptain",
        "title": "%command.showOpenCodeStatus.title%"
      },
      {
        "command": "codecaptain.openAgentManager",
        "category": "CodeCaptain",
        "title": "%command.openAgentManager.title%",
        "icon": "$(circuit-board)"
      },
      {
        "command": "codecaptain.openActiveSessionInEditor",
        "category": "CodeCaptain",
        "title": "%command.openActiveSessionInEditor.title%",
        "icon": "$(link-external)"
      },
      {
        "command": "codecaptain.openNewSessionInEditor",
        "category": "CodeCaptain",
        "title": "%command.openNewSessionInEditor.title%",
        "icon": {
          "light": "assets/icon.svg",
          "dark": "assets/icon-titlebar.svg"
        }
      },
      {
        "command": "codecaptain.openCurrentOrNewSessionInEditor",
        "category": "CodeCaptain",
        "title": "%command.openCurrentOrNewSessionInEditor.title%",
        "icon": "$(link-external)"
      },
      {
        "command": "codecaptain.addToContext",
        "category": "CodeCaptain",
        "title": "%command.addToContext.title%"
      },
      {
        "command": "codecaptain.explain",
        "category": "CodeCaptain",
        "title": "%command.explain.title%"
      },
      {
        "command": "codecaptain.improveCode",
        "category": "CodeCaptain",
        "title": "%command.improveCode.title%"
      },
      {
        "command": "codecaptain.newSession",
        "category": "CodeCaptain",
        "title": "%command.newSession.title%",
        "icon": "$(add)"
      },
      {
        "command": "codecaptain.showSettings",
        "category": "CodeCaptain",
        "title": "%command.showSettings.title%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "codecaptain.attachExplorerToChat",
        "category": "CodeCaptain",
        "title": "%command.attachExplorerToChat.title%"
      }
    ],
    "submenus": [
      {
        "id": "codecaptain.submenu",
        "label": "CodeCaptain"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "codecaptain.submenu",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "codecaptain.attachExplorerToChat",
          "when": "resourceScheme == file && explorerResourceIsFolder == false",
          "group": "navigation@50"
        }
      ],
      "editor/title": [
        {
          "command": "codecaptain.openNewSessionInEditor",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "codecaptain.newSession",
          "when": "view == codecaptain.chatView",
          "group": "navigation@1"
        },
        {
          "command": "codecaptain.openCurrentOrNewSessionInEditor",
          "when": "view == codecaptain.chatView",
          "group": "navigation@2"
        },
        {
          "command": "codecaptain.openAgentManager",
          "when": "view == codecaptain.chatView",
          "group": "navigation@3"
        },
        {
          "command": "codecaptain.showSettings",
          "when": "view == codecaptain.chatView",
          "group": "navigation@4"
        }
      ],
      "codecaptain.submenu": [
        {
          "command": "codecaptain.explain"
        },
        {
          "command": "codecaptain.improveCode"
        },
        {
          "command": "codecaptain.addToContext"
        }
      ]
    },
    "configuration": {
      "title": "CodeCaptain",
      "properties": {
        "codecaptain.apiUrl": {
          "type": "string",
          "default": "",
          "description": "%configuration.apiUrl.description%"
        },
        "codecaptain.opencodeBinary": {
          "type": "string",
          "default": "",
          "description": "%configuration.opencodeBinary.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run build",
    "build": "bun run build:extension && bun run build:webview",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --main-fields=module,main",
    "build:webview": "VITE_OPENCODE_URL=/api vite build",
    "dev": "concurrently -n \"ext,web\" -c \"cyan,magenta\" \"bun run watch:extension\" \"bun run dev:webview\"",
    "dev:webview": "vite --host localhost --port 5173 --strictPort",
    "watch:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch --sourcemap --main-fields=module,main",
    "watch:webview": "vite build --watch",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "lint": "bun x eslint --ext .ts,.tsx src webview",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vscode/vsce": "^3.2.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "typescript": "~5.9.0",
    "vite": "^7.1.2"
  },
  "dependencies": {
    "@codecaptain/ui": "workspace:*",
    "@opencode-ai/sdk": "^1.17.9",
    "adm-zip": "^0.5.16",
    "jsonc-parser": "^3.3.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yaml": "^2.8.1"
  }
}
