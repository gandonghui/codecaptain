{
  "$schema": "https://opencode.ai/config.json",
  "model": "MedGateway/ag/gemini-pro-agent",
  "enabled_providers": ["MedGateway"],
  "agent": {
      "build": { "model": "MedGateway/ag/gemini-pro-agent" },
      "plan": { "model": "MedGateway/ag/gemini-pro-agent" }
  },
  "lsp": {
    "tailwindcss": {
      "command": ["tailwindcss-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".css", ".html"]
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html"]
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "mdx": {
      "command": ["mdx-language-server", "--stdio"],
      "extensions": [".mdx"]
    },
    "marksman": {
      "command": ["marksman", "server"],
      "extensions": [".md"]
    },
    "dockerfile": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": ["Dockerfile", ".dockerfile"]
    }
  }
}
